# Frontend: set this when building the GitHub Pages site.
VITE_API_BASE_URL=https://your-render-service.onrender.com

# Backend: use these in Render or local server deployment.
PORT=3001
FRONTEND_ORIGIN=https://your-live-site.example.com
ADDITIONAL_FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VLC_AUTH_SECRET=replace-with-a-long-random-secret
VLC_ADMIN_USERNAME=admin
VLC_ADMIN_PASSWORD=ChangeMe123!
VLC_DATA_DIR=./server/data
